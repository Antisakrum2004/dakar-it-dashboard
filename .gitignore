# ============================================================================
# .gitignore — dakar-it-dashboard
# ============================================================================

# ---- Файлы с секретами (НИКОГДА не коммитить!) ----
# Это критично: файлы config.js и .env содержат вебхуки Bitrix24
# с токенами. Репозиторий публичный — утечка = полный доступ к порталам.
config.js
.env
.env.local
.env.*.local

# ---- OS / Editor ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Зависимости (если появятся) ----
node_modules/

# ---- Временные файлы ----
*.tmp
*.bak
*.cache
