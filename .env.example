# ============================================================================
# .env.example — шаблон конфигурации dakar-it-dashboard
# ============================================================================
# Скопируйте этот файл в `.env` и подставьте реальные значения.
# Файл `.env` НИКОГДА не коммитится (он в .gitignore).
#
# Этот файл нужен в основном для локальной разработки и для сборки config.js
# перед публикацией. В самом репозитории (публичном) будут только переменные
# из этого шаблона — без реальных токенов.
# ============================================================================

# ---- Вебхук Bitrix24 — Дакар (CRM) ----
# Формат: https://<портал>.bitrix24.ru/rest/<user_id>/<webhook_secret>/
# Скоупы у этого вебхука: crm, lists, log, sonet_group, task, tasks, tasks_extended, user
# (НЕТ im и disk — ограничение вебхука)
BITRIX_DAKAR_WEBHOOK_URL=https://dakar.bitrix24.ru/rest/REPLACE_DAKAR_USER_ID/REPLACE_DAKAR_WEBHOOK_SECRET/
BITRIX_DAKAR_ENTITY_TYPE_ID=129

# ---- Вебхук Bitrix24 — 1c-cms (Tasks + IM + Disk) ----
# Используется для вкладок АтиЛаб и Внедрение
# Скоупы: disk, entity, im, im.import, log, sonet_group, task, tasks, tasks_extended, user
# (ЕСТЬ im и disk — критично для чата ВНЕДРЕНИЯ)
BITRIX_ATILAB_WEBHOOK_URL=https://1c-cms.bitrix24.ru/rest/REPLACE_ATILAB_USER_ID/REPLACE_ATILAB_WEBHOOK_SECRET/

# ---- Чат ВНЕДРЕНИЯ (на портале 1c-cms.bitrix24.ru) ----
BITRIX_VNEDRENIE_CHAT_DIALOG_ID=chat7568
BITRIX_VNEDRENIE_TASK_URL=https://1c-cms.bitrix24.ru/company/personal/user/REPLACE_ATILAB_USER_ID/tasks/task/view/

# ---- Опционально: GitHub PAT для скриптов (если будете пушить через скрипты) ----
# Этот токен НЕ нужен для работы дашборда — только для автоматизации
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_GITHUB_PAT

# ---- Опционально: Vercel токен ----
VERCEL_TOKEN=vcp_REPLACE_WITH_YOUR_VERCEL_TOKEN
